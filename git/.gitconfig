[alias]
    # 基本
    st = status
    ad = !git add . && git status
    cm = commit -m
    co = checkout
    br = branch
    df = diff

    # ログ（見やすい）
    lg = log --oneline --graph --decorate
    lga = log --oneline --graph --decorate --all
    lgg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    last = log -1 HEAD

    # プッシュ
    p = push origin HEAD
    
    # リセット
    undo = reset --soft HEAD^

    # 便利
    amend = commit --amend --no-edit
    aliases = config --get-regexp alias

    # ブランチクリーンアップ
    cleanup = !git branch --merged | grep -v '\\*\\|main\\|master\\|develop' | xargs -n 1 git branch -d

    # タイムスタンプでコミット
    snap = !git commit -m \"$(date +%Y-%m-%d_%H:%M:%S)\"

[user]
    name = JunichiHattori
    email = junhat6@gmail.com

[init]
    defaultBranch = main

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true      # n/N でファイル間を移動
    side-by-side = true  # 左右に並べて差分表示
    line-numbers = true
    syntax-theme = Catppuccin Latte
    light = true

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default
